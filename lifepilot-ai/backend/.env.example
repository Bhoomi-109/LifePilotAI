# LifePilot AI - Environment Configurations

# Express Server Port
PORT=3000

# Server Environment (development / production)
NODE_ENV=development

# Gemini API Key (obtain from https://aistudio.google.com/)
# The @google/genai SDK checks for GEMINI_API_KEY or GOOGLE_API_KEY
GEMINI_API_KEY=your_gemini_api_key_here

# Enable Mock Mode for AI when no API key is present (true/false)
# If true, the system will generate rich mock responses so the app is fully functional without a key.
ENABLE_MOCK_AI=true
